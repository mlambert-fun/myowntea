// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

enum Role {
  ADMIN
  CUSTOMER
  GUEST
}

enum AuthProvider {
  PASSWORD
  GOOGLE
}

enum Salutation {
  MME
  MR
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(CUSTOMER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  customer      Customer?
  orders        Order[]
}

model Customer {
  id            String   @id @default(cuid())
  userId        String?  @unique
  email         String?  @unique
  passwordHash  String?
  googleId      String?  @unique
  authProvider  AuthProvider @default(PASSWORD)
  salutation    Salutation?
  firstName     String?
  lastName      String?
  birthDate     DateTime?
  phone         String?
  phoneE164     String?
  address       String
  city          String
  postalCode    String
  country       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders        Order[]
  carts         Cart[]
  wishlistCreations WishlistCreation[]
  sessions      Session[]
  subscriptions Subscription[]
  addresses     Address[]
  passwordResetTokens PasswordResetToken[]
  emailPreference EmailPreference?
  emailDeliveries EmailDelivery[]
  emailCampaignLogs EmailCampaignLog[]
}

model PasswordResetToken {
  id              String   @id @default(cuid())
  customerId      String
  tokenHash       String   @unique
  expiresAt       DateTime
  usedAt          DateTime?
  requestedFromIp String?
  userAgent       String?
  createdAt       DateTime @default(now())

  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([expiresAt])
}

model EmailPreference {
  id                 String   @id @default(cuid())
  customerId         String   @unique
  transactionalOptIn Boolean  @default(true)
  marketingOptIn     Boolean  @default(true)
  abandonedCartOptIn Boolean  @default(true)
  postPurchaseOptIn  Boolean  @default(true)
  reorderOptIn       Boolean  @default(true)
  winbackOptIn       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model EmailDelivery {
  id                String   @id @default(cuid())
  customerId        String?
  orderId           String?
  campaignKey       String?
  type              String
  channel           String   @default("EMAIL")
  recipient         String
  subject           String
  payload           Json?
  status            String   @default("PENDING")
  provider          String   @default("SMTP")
  providerMessageId String?
  error             String?
  attemptCount      Int      @default(0)
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order             Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  campaignLogs      EmailCampaignLog[]

  @@index([status, nextAttemptAt])
  @@index([createdAt])
  @@index([customerId])
  @@index([orderId])
}

model EmailCampaignLog {
  id              String   @id @default(cuid())
  customerId      String
  orderId         String?
  cartId          String?
  campaignKey     String
  emailDeliveryId String?
  createdAt       DateTime @default(now())

  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  cart            Cart?         @relation(fields: [cartId], references: [id], onDelete: SetNull)
  emailDelivery   EmailDelivery? @relation(fields: [emailDeliveryId], references: [id], onDelete: SetNull)

  @@unique([customerId, campaignKey])
  @@index([campaignKey])
  @@index([orderId])
  @@index([cartId])
}

model Address {
  id               String   @id @default(cuid())
  customerId       String
  salutation       Salutation?
  firstName        String
  lastName         String
  countryCode      String
  postalCode       String
  city             String
  hamlet           String?
  address1         String
  address2         String?
  phoneE164        String
  isDefaultBilling Boolean  @default(false)
  isDefaultShipping Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ============================================================================
// PRODUCTS & INGREDIENTS
// ============================================================================

model Ingredient {
  id            String   @id @default(cuid())
  name          String
  description   String   @db.Text
  longDescription String? @db.Text
  category      String   // "base", "flavor", "flower", etc.
  flavor        String?  // Legacy column (keep for DB compatibility)
  flavors       String[] // Nouvelles saveurs multiples
  image         String   // URL to image
  color         String   // Hex color for UI
  intensity     Int      @default(3) // 1-5 scale
  umami         Int      @default(3) // 1-5 scale
  sweetness     Int      @default(3) // 1-5 scale
  thickness     Int      @default(3) // 1-5 scale
  finish        Int      @default(3) // 1-5 scale
  benefits      String[] // Array of benefit strings
  dayMoments    Json?
  infusionTime  String?
  dosage        String?
  temperature   String?
  preparation   String?  @db.Text
  origin        String?
  pairing       String?  @db.Text
  price         Float    @default(0) // Price per unit
  stock         Int      @default(100)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  blends        BlendIngredient[]

  @@unique([name, category])
}

model Blend {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  color         String
  coverImageUrl String?
  ingredients   BlendIngredient[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems     CartItem[]
  listings      BlendListing[]
}

model BlendIngredient {
  id            String   @id @default(cuid())
  blendId       String
  ingredientId  String
  quantity      Int      @default(1)
  
  blend         Blend    @relation(fields: [blendId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
  
  @@unique([blendId, ingredientId])
}

// ============================================================================
// ORDERS & CHECKOUT
// ============================================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DiscountMethod {
  AUTOMATIC
  CODE
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
  BOGO
  TIERED
  BUNDLE
  SALE_PRICE
  SUBSCRIPTION
  GIFT
}

enum DiscountScope {
  ORDER
  SHIPPING
  PRODUCTS
  CATEGORIES
}

enum DiscountStatus {
  ACTIVE
  DRAFT
  EXPIRED
}

enum CartStatus {
  ACTIVE
  ORDERED
}

enum CartItemType {
  BLEND
  VARIANT
  PACK
  SUBSCRIPTION
}

model Order {
  id              String   @id @default(cuid())
  customerId      String
  userId          String?
  orderNumber     String   @unique // Human-readable order ID
  status          OrderStatus @default(PENDING)
  subtotal        Float    // Sum of items
  shippingCost    Float    @default(0)
  tax             Float    @default(0)
  total           Float    // Final total
  subtotalCents   Int      @default(0)
  shippingCents   Int      @default(0)
  discountTotalCents Int   @default(0)
  totalCents      Int      @default(0)
  appliedDiscounts Json?
  appliedDiscountCode String?
  comment         String?  @db.Text // Customer special requests
  shippingAddress String   @db.Text
  billingAddressSnapshot Json?
  shippingAddressSnapshot Json?
  shippingMethod  String?  // Shipping provider name
  trackingNumber  String?
  trackingUrl     String?
  shippingProvider String?
  shippingMode    String?
  shippingOfferId String?
  shippingOfferCode String?
  shippingOfferLabel String?
  relayPointId    String?
  relayPointLabel String?
  relayNetwork    String?
  shippingMeta    Json?
  paymentMethod   String?  // e.g., "stripe", "paypal"
  paymentStatus   String   @default("pending") // "pending", "completed", "failed"
  stripeSessionId String?
  cartId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  paymentRecord   Payment?
  discountRedemptions DiscountRedemption[]
  shipment        Shipment?
  discountApplications OrderDiscountApplication[]
  blendListings   BlendListing[]
  emailDeliveries EmailDelivery[]
  emailCampaignLogs EmailCampaignLog[]
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  quantity      Int      @default(1)
  price         Float    @default(0) // Legacy price
  ingredientName  String   @default("Ingrédient")
  ingredientColor String   @default("#6B7280")
  itemType      CartItemType? @default(BLEND)
  qty           Int      @default(1)
  unitPriceCents Int      @default(0)
  snapshot      Json?
  lineSubtotalCents Int   @default(0)
  lineDiscountCents Int   @default(0)
  lineTotalCents Int      @default(0)
  subscriptionPlanId String?
  
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  discountApplications OrderDiscountApplication[]
  
  @@index([orderId])
}

model Session {
  id         String   @id @default(cuid())
  customerId String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@index([customerId])
}

model Cart {
  id         String     @id @default(cuid())
  customerId String
  status     CartStatus @default(ACTIVE)
  currency   String     @default("EUR")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  discountApplications CartDiscountApplication[]
  emailCampaignLogs EmailCampaignLog[]
  @@index([customerId, status])
}

model CartItem {
  id             String       @id @default(cuid())
  cartId         String
  itemType       CartItemType
  qty            Int          @default(1)
  unitPriceCents Int          @default(0)
  snapshot       Json
  blendId        String?
  variantId      String?
  subscriptionPlanId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cart           Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  blend          Blend?        @relation(fields: [blendId], references: [id], onDelete: SetNull)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  subscriptionPlan SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  discountApplications CartDiscountApplication[]

  @@index([cartId])
  @@index([variantId])
}

model WishlistCreation {
  id         String   @id @default(cuid())
  customerId String
  snapshot   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model Product {
  id          String   @id @default(cuid())
  type        String   @default("ACCESSORY")
  title       String
  slug        String   @unique
  description String?
  priceCents  Int      @default(0)
  stockQty    Int?
  images      String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options     ProductOption[]
  variants    ProductVariant[]
  subscriptionPlans SubscriptionPlan[]
  packItems    PackItem[] @relation("PackProduct")
}

model ProductOption {
  id         String   @id @default(cuid())
  productId  String
  name       String
  position   Int      @default(0)

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  values     ProductOptionValue[]

  @@index([productId])
}

model ProductOptionValue {
  id        String   @id @default(cuid())
  optionId  String
  value     String
  position  Int      @default(0)

  option    ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantValues VariantOptionValue[]

  @@index([optionId])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  sku         String?  @unique
  priceCents  Int
  stockQty    Int?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues VariantOptionValue[]
  cartItems   CartItem[]
  packComponents PackItem[] @relation("PackComponent")

  @@index([productId])
}

model VariantOptionValue {
  id            String   @id @default(cuid())
  variantId     String
  optionValueId String

  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([optionValueId])
}

model PackItem {
  id                 String   @id @default(cuid())
  packProductId      String
  componentVariantId String
  qty                Int      @default(1)

  packProduct        Product        @relation("PackProduct", fields: [packProductId], references: [id], onDelete: Cascade)
  componentVariant   ProductVariant @relation("PackComponent", fields: [componentVariantId], references: [id], onDelete: Cascade)

  @@index([packProductId])
  @@index([componentVariantId])
  @@unique([packProductId, componentVariantId])
}

model BlendListing {
  id                 String   @id @default(cuid())
  blendId            String
  createdFromOrderId String?
  createdBy          String?
  title              String
  slug               String   @unique
  description        String?  @db.Text
  coverImageUrl      String?
  isActive           Boolean  @default(false)
  ranking            Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  blend              Blend    @relation(fields: [blendId], references: [id], onDelete: Cascade)
  createdFromOrder   Order?   @relation(fields: [createdFromOrderId], references: [id], onDelete: SetNull)

  @@index([blendId])
  @@index([isActive])
  @@index([ranking])
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  productId       String
  interval        String   @default("month")
  intervalCount   Int      @default(1)
  stripePriceId   String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([productId])
}

model Subscription {
  id                    String   @id @default(cuid())
  customerId            String
  planId                String
  status                String
  stripeSubscriptionId  String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([planId])
  @@unique([stripeSubscriptionId])
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  providerId    String
  externalId    String   // Payment provider transaction ID
  amount        Float
  currency      String   @default("EUR")
  status        String   // "pending", "completed", "failed"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      PaymentProvider @relation(fields: [providerId], references: [id])
}

model Shipment {
  id               String   @id @default(cuid())
  orderId          String   @unique
  provider         String   @default("BOXTAL")
  providerOrderId  String?
  offerId          String?
  offerCode        String?
  offerLabel       String?
  status           String?  // provider status
  statusInternal   String   @default("CREATED")
  trackingNumber   String?
  labelUrl         String?
  priceCents       Int      @default(0)
  currency         String   @default("EUR")
  relayPointId     String?
  relayNetwork     String?
  payload          Json?
  response         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events           ShipmentEvent[]
}

model ShipmentEvent {
  id           String   @id @default(cuid())
  shipmentId   String
  eventType    String
  status       String?
  occurredAt   DateTime?
  payload      Json?
  createdAt    DateTime @default(now())

  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

// ============================================================================
// INTEGRATIONS
// ============================================================================

enum ProviderType {
  PAYMENT
  SHIPPING
}

model PaymentProvider {
  id            String   @id @default(cuid())
  name          String   // "Stripe", "PayPal", etc.
  type          ProviderType @default(PAYMENT)
  isActive      Boolean  @default(true)
  config        Json     // API keys, webhook URLs, etc. (encrypted in production)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  payments      Payment[]
}

model ShippingProvider {
  id            String   @id @default(cuid())
  name          String   // "Colissimo", "DHL", etc.
  type          ProviderType @default(SHIPPING)
  isActive      Boolean  @default(true)
  config        Json     // API keys, rate tables, zones, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================================
// ADMIN CONFIGURATION
// ============================================================================

model SiteConfig {
  id            String   @id @default("default")
  siteName      String   @default("My Own Tea")
  companyEmail  String
  supportPhone  String?
  taxRate       Float    @default(0.20) // 20% VAT for EU
  currency      String   @default("EUR")
  shippingRates Json     // Base shipping rates by country/region
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?  // Admin who performed action
  action        String   // "CREATE_INGREDIENT", "CANCEL_ORDER", etc.
  resourceType  String   // "Order", "Ingredient", "Payment"
  resourceId    String   // ID of affected resource
  changes       Json?    // Before/after if applicable
  ipAddress     String?
  createdAt     DateTime @default(now())
  
  @@index([userId])
  @@index([resourceType, resourceId])
}

// ============================================================================
// DISCOUNTS & PROMOTIONS
// ============================================================================

model Discount {
  id                  String         @id @default(cuid())
  title               String
  method              DiscountMethod
  code                String?        @unique
  type                DiscountType
  scope               DiscountScope  @default(ORDER)
  config              Json?
  valuePercent        Int?
  valueCents          Int?
  minimumSubtotalCents Int?          @default(0)
  startAt             DateTime?
  endAt               DateTime?
  usageLimitTotal     Int?
  usageLimitPerCustomer Int?
  redemptionCount     Int            @default(0)
  stackable           Boolean        @default(false)
  firstOrderOnly      Boolean        @default(false)
  status              DiscountStatus @default(DRAFT)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  redemptions         DiscountRedemption[]

  @@index([status, method])
  @@index([type])
}

model DiscountRedemption {
  id            String   @id @default(cuid())
  discountId    String
  orderId       String?
  customerEmail String?
  createdAt     DateTime @default(now())

  discount      Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([discountId])
  @@index([customerEmail])
  @@unique([discountId, orderId])
}

model StoreSettings {
  id                        String   @id @default("default")
  freeShippingThresholdCents Int     @default(4500)
  defaultShippingCents      Int      @default(590)
  currency                  String   @default("EUR")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model CartDiscountApplication {
  id            String   @id @default(cuid())
  cartId        String
  cartItemId    String?
  discountId    String
  label         String
  type          DiscountType
  scope         DiscountScope
  amountCents   Int
  snapshot      Json?
  createdAt     DateTime @default(now())

  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartItem      CartItem? @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([cartItemId])
  @@index([discountId])
}

model OrderDiscountApplication {
  id            String   @id @default(cuid())
  orderId       String
  orderItemId   String?
  discountId    String
  label         String
  type          DiscountType
  scope         DiscountScope
  amountCents   Int
  snapshot      Json?
  createdAt     DateTime @default(now())

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem     OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderItemId])
  @@index([discountId])
}
